APP_NAME=kts.blackbirdzzzz.art API
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://dev:devpass@localhost:15432/ai_architect
REDIS_URL=redis://localhost:16379/0
GPU_SERVICE_URL=http://localhost:18001
PUBLIC_BASE_URL=http://localhost:3000
JWT_SECRET=change-me
CELERY_TASK_ALWAYS_EAGER=false
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-5.4
LLM_REQUEST_TIMEOUT_SECONDS=60
S3_ENDPOINT_URL=http://localhost:19000
S3_PUBLIC_ENDPOINT_URL=http://localhost:19000
# Docker Desktop local note:
# If presigned PUT/GET from host/browser fails because the signed host is internal-only,
# point both S3_ENDPOINT_URL and S3_PUBLIC_ENDPOINT_URL to a LAN IP reachable from
# both Docker containers and the host browser, for example http://192.168.1.88:19000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-architect-assets
S3_REGION=us-east-1
S3_SECURE=false
